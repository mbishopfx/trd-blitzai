# Shared
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_ENCRYPTION_KEY=replace-with-32-byte-secret

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth / GBP
GOOGLE_OAUTH_CLIENT_ID=
