# Shared
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_ENCRYPTION_KEY=replace-with-32-byte-secret

# Supabase
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CLIENT_MEDIA_MAX_BYTES=52428800

# Google OAuth / GBP
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
TINYURL_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=

# Queue / Worker TS
REDIS_URL=redis://localhost:6379
BLITZ_WORKER_CONCURRENCY=4
SCHEDULED_CONTENT_DISPATCHER_ENABLED=true
SCHEDULED_CONTENT_POLL_MS=60000
SCHEDULED_CONTENT_BATCH_SIZE=8
BLITZ_REVIEW_REQUEST_DRY_RUN=false

# Review ignition webhooks + outbound messaging
BLITZ_REVIEW_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Blitz Agent

# OpenAI
OPENAI_API_KEY=

# Gemini (Google AI Studio)
GEMINI_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Python worker defaults
WORKER_PY_HOST=0.0.0.0
WORKER_PY_PORT=8001
GOOGLE_ADS_API_VERSION=v22
REQUEST_TIMEOUT_SECONDS=120
GOOGLE_OAUTH_CLIENT_SECRETS_FILE=newclawads.json
